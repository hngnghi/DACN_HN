@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="flex justify-center items-center min-h-[60vh]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-lg shadow-xl overflow-hidden">
            <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white text-center py-6">
                <h4 class="text-2xl font-bold">ĐĂNG NHẬP HỆ THỐNG</h4>
            </div>
            <div class="p-8">
                @if (ViewBag.Error != null)
                {
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg flex items-center">
                        <i class="fa-solid fa-circle-exclamation mr-2"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                <form asp-action="Login" method="post" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Tên đăng nhập</label>
                        <input type="text" name="tenDangNhap" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required placeholder="Nhập tên đăng nhập..." />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Mật khẩu</label>
                        <input type="password" name="matKhau" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required placeholder="Nhập mật khẩu..." />
                    </div>
                    <div>
                        <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg">
                            <i class="fa-solid fa-right-to-bracket mr-2"></i>Đăng nhập
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>