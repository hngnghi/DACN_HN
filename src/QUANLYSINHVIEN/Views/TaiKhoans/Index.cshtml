@model IEnumerable<QUANLYSINHVIEN.Models.TaiKhoan>

@{
    ViewData["Title"] = "Quản lý Tài khoản";
}

<div class="mb-6">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-3xl font-bold text-gray-900">Danh sách Tài khoản</h1>
        <a asp-action="Create" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg">
            <i class="fa-solid fa-plus mr-2"></i>Tạo mới
        </a>
    </div>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.TenDangNhap)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.VaiTro)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.MaGvNavigation)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.MaSvNavigation)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Thao tác
                    </th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var item in Model) {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm font-medium text-gray-900">@Html.DisplayFor(modelItem => item.TenDangNhap)</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                                @(item.VaiTro == "Admin" ? "bg-purple-100 text-purple-800" : 
                                  item.VaiTro == "GiangVien" ? "bg-blue-100 text-blue-800" : 
                                  "bg-green-100 text-green-800")">
                                @Html.DisplayFor(modelItem => item.VaiTro)
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-500">@Html.DisplayFor(modelItem => item.MaGvNavigation.MaGv)</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-500">@Html.DisplayFor(modelItem => item.MaSvNavigation.MaSv)</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                            <a asp-action="Edit" asp-route-id="@item.TenDangNhap" class="text-blue-600 hover:text-blue-900 mr-3">
                                <i class="fa-solid fa-edit"></i> Sửa
                            </a>
                            <a asp-action="Details" asp-route-id="@item.TenDangNhap" class="text-green-600 hover:text-green-900 mr-3">
                                <i class="fa-solid fa-eye"></i> Chi tiết
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.TenDangNhap" class="text-red-600 hover:text-red-900">
                                <i class="fa-solid fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
