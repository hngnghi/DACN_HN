@model QUANLYSINHVIEN.Models.SinhVien

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="flex justify-center py-10">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden w-full max-w-4xl flex flex-col md:flex-row">

        <div class="bg-gradient-to-b from-blue-500 to-blue-700 w-full md:w-1/3 p-8 text-white text-center flex flex-col items-center justify-center">
            <div class="bg-white p-1 rounded-full mb-4 shadow-lg">
                <img src="https://ui-avatars.com/api/?name=@Model.HoTen&size=128&background=random" class="rounded-full w-32 h-32" alt="Avatar">
            </div>
            <h2 class="text-2xl font-bold mb-1">@Model.HoTen</h2>
            <p class="text-blue-100 text-sm uppercase tracking-wider">Sinh viên</p>
            <div class="mt-6 w-full">
                <a asp-action="ChangePassword" class="block w-full py-2 px-4 bg-white/20 hover:bg-white/30 rounded-lg transition text-sm font-medium mb-2">
                    <i class="fa-solid fa-key mr-2"></i> Đổi mật khẩu
                </a>
            </div>
        </div>

        <div class="w-full md:w-2/3 p-8">
            <h3 class="text-xl font-bold text-gray-800 mb-6 border-b pb-2">THÔNG TIN HỒ SƠ</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Mã Sinh Viên</label>
                    <p class="text-gray-800 font-medium text-lg">@Model.MaSv</p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Lớp</label>
                    <p class="text-gray-800 font-medium text-lg">@(Model.MaLopNavigation?.TenLop ?? Model.MaLop)</p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Ngày Sinh</label>
                    <p class="text-gray-800 font-medium">@Model.NgaySinh.ToString("dd/MM/yyyy")</p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Giới Tính</label>
                    <p class="text-gray-800 font-medium">@Model.GioiTinh</p>
                </div>
                <div class="col-span-1 md:col-span-2">
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Email</label>
                    <p class="text-gray-800 font-medium">@Model.Email</p>
                </div>
                <div class="col-span-1 md:col-span-2">
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Địa Chỉ</label>
                    <p class="text-gray-800 font-medium">@Model.DiaChi</p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Trạng thái</label>
                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                        @Model.TrangThaiHocTap
                    </span>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase block mb-1">GPA Tích lũy</label>
                    <p class="text-blue-600 font-bold text-xl">@Model.DiemTrungBinh</p>
                </div>
            </div>
        </div>
    </div>
</div>