@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

<div class="flex justify-center items-center py-10 min-h-[60vh]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100 p-8">
            <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">ĐỔI MẬT KHẨU</h2>

            @if (ViewBag.Success != null)
            {
                <div class="bg-green-50 text-green-700 p-3 rounded mb-4 text-sm font-medium text-center">
                    <i class="fa-solid fa-check-circle mr-1"></i> @ViewBag.Success
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-700 p-3 rounded mb-4 text-sm font-medium text-center">
                    <i class="fa-solid fa-circle-exclamation mr-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="ChangePassword" method="post" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu hiện tại</label>
                    <input type="password" name="CurrentPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu mới</label>
                    <input type="password" name="NewPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Xác nhận mật khẩu mới</label>
                    <input type="password" name="ConfirmPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
                </div>

                <div class="pt-2">
                    <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded-lg font-bold hover:bg-blue-700 transition shadow-md">
                        Cập nhật mật khẩu
                    </button>
                </div>
            </form>

            <div class="mt-4 text-center">
                <a asp-action="Profile" class="text-sm text-gray-500 hover:text-blue-600">Quay lại hồ sơ</a>
            </div>
        </div>
    </div>
</div>