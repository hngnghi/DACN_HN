@using Microsoft.AspNetCore.Http
@model IEnumerable<QUANLYSINHVIEN.Models.SinhVien>

@{
    ViewData["Title"] = "Quản lý Sinh viên";
    var userRole = Context.Session.GetString("Role");
}

<div class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-800 flex items-center">
                <i class="fa-solid fa-users text-blue-600 mr-3"></i>
                DANH SÁCH SINH VIÊN
            </h1>
            <p class="text-gray-500 mt-1">Quản lý hồ sơ và thông tin học tập của sinh viên.</p>
        </div>

        @if (userRole == "Admin")
        {
            <div class="flex space-x-2">
                <a asp-action="Import" class="inline-flex items-center px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors shadow-md transform hover:-translate-y-0.5">
                    <i class="fa-solid fa-file-import mr-2"></i> Import Excel
                </a>

                <a asp-action="Create" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors shadow-md transform hover:-translate-y-0.5">
                    <i class="fa-solid fa-plus mr-2"></i> Tạo mới
                </a>
            </div>
        }
    </div>

    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Họ và Tên</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Ngày Sinh</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Giới Tính</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Lớp</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">GPA</th>
                        <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Trạng Thái</th>
                        <th class="px-6 py-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-blue-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-xs mr-3">
                                        @item.HoTen.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-900">@Html.DisplayFor(modelItem => item.HoTen)</div>
                                        <div class="text-xs text-gray-500">@item.MaSv</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                @Html.DisplayFor(modelItem => item.NgaySinh)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                @Html.DisplayFor(modelItem => item.GioiTinh)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs border border-gray-200">
                                    @Html.DisplayFor(modelItem => item.MaLopNavigation.MaLop)
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-blue-600">
                                @Html.DisplayFor(modelItem => item.DiemTrungBinh)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full
                                    @(item.TrangThaiHocTap == "Đang học" ? "bg-green-100 text-green-800" :
                                      item.TrangThaiHocTap == "Tốt nghiệp" ? "bg-blue-100 text-blue-800" :
                                      "bg-red-100 text-red-800")">
                                    @Html.DisplayFor(modelItem => item.TrangThaiHocTap)
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a asp-action="Details" asp-route-id="@item.MaSv" class="text-gray-600 hover:text-gray-900 mx-2" title="Xem chi tiết">
                                    <i class="fa-solid fa-circle-info"></i>
                                </a>

                                @if (userRole == "Admin")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.MaSv" class="text-indigo-600 hover:text-indigo-900 mx-2" title="Sửa thông tin">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaSv" class="text-red-600 hover:text-red-900 mx-2" title="Xóa sinh viên">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-gray-50 px-6 py-3 border-t border-gray-200 text-xs text-gray-500 flex justify-between items-center">
            <span>Hiển thị @Model.Count() sinh viên</span>
        </div>
    </div>
</div>