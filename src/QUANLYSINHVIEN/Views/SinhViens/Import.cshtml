@{
    ViewData["Title"] = "Import Sinh Viên từ Excel";
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="bg-blue-600 px-6 py-4">
            <h2 class="text-2xl font-bold text-white flex items-center">
                <i class="fa-solid fa-file-import mr-3"></i> Nhập dữ liệu Sinh viên
            </h2>
        </div>

        <div class="p-6">
            @if (ViewBag.Success != null)
            {
                <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
                    <p class="font-bold">Thành công!</p>
                    <p>@ViewBag.Success</p>
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
                    <p class="font-bold">Cảnh báo!</p>
                    <p>@ViewBag.Error</p>
                    @if (ViewBag.LoiChiTiet != null)
                    {
                        <ul class="list-disc list-inside mt-2 text-sm">
                            @foreach (var loi in ViewBag.LoiChiTiet)
                            {
                                <li>@loi</li>
                            }
                        </ul>
                    }
                </div>
            }

            <form asp-action="Import" method="post" enctype="multipart/form-data" class="space-y-6">

                <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-blue-500 transition-colors">
                    <i class="fa-solid fa-file-excel text-green-600 text-5xl mb-4"></i>
                    <p class="text-gray-600 mb-4">Chọn file Excel (.xlsx) chứa danh sách sinh viên</p>

                    <input type="file" name="file" accept=".xlsx" class="block w-full text-sm text-gray-500
                        file:mr-4 file:py-2 file:px-4
                        file:rounded-full file:border-0
                        file:text-sm file:font-semibold
                        file:bg-blue-50 file:text-blue-700
                        hover:file:bg-blue-100" />
                </div>

                <div class="bg-blue-50 p-4 rounded-lg">
                    <h5 class="font-bold text-blue-800 mb-2 text-sm">Lưu ý cấu trúc file Excel:</h5>
                    <p class="text-xs text-blue-600">Dòng 1 là tiêu đề. Dữ liệu bắt đầu từ dòng 2.</p>
                    <ul class="list-decimal list-inside text-xs text-blue-700 mt-1">
                        <li>Cột 1: Mã Sinh Viên (Bắt buộc)</li>
                        <li>Cột 2: Họ Tên</li>
                        <li>Cột 3: Ngày Sinh (dd/MM/yyyy)</li>
                        <li>Cột 4: Giới Tính</li>
                        <li>Cột 5: Địa Chỉ</li>
                        <li>Cột 6: Email</li>
                        <li>Cột 7: Mã Lớp (Phải tồn tại trong hệ thống)</li>
                    </ul>
                </div>

                <div class="flex items-center justify-between">
                    <a asp-action="Index" class="text-gray-600 hover:text-gray-800 font-medium">
                        <i class="fa-solid fa-arrow-left mr-1"></i> Quay lại
                    </a>
                    <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors shadow-md font-bold">
                        <i class="fa-solid fa-upload mr-2"></i> Tiến hành Import
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>