@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-12">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold text-gray-900 mb-6">Chào mừng đến với Hệ thống Quản lý Sinh viên</h1>
        <p class="text-xl text-gray-600 mb-8">Hệ thống quản lý toàn diện cho việc quản lý sinh viên, điểm số và phân tích dữ liệu</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
            <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
                <div class="text-blue-600 text-4xl mb-4">
                    <i class="fa-solid fa-users"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Quản lý Sinh viên</h3>
                <p class="text-gray-600">Quản lý thông tin sinh viên, lớp học và khoa</p>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
                <div class="text-green-600 text-4xl mb-4">
                    <i class="fa-solid fa-chart-line"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Theo dõi Điểm số</h3>
                <p class="text-gray-600">Nhập và xem điểm số của sinh viên</p>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow">
                <div class="text-purple-600 text-4xl mb-4">
                    <i class="fa-solid fa-brain"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Phân tích AI</h3>
                <p class="text-gray-600">Dự báo kết quả học tập bằng AI</p>
            </div>
        </div>
    </div>
</div>
