@model QUANLYSINHVIEN.Models.BangDiem

@{
    ViewData["Title"] = "Chi tiết Bảng Điểm";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Chi tiết Bảng Điểm</h1>
    <p class="text-gray-600 mt-2">Thông tin chi tiết về điểm số</p>
</div>

<div class="bg-white rounded-lg shadow-md p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.MaSvNavigation)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.MaSvNavigation.MaSv)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.MaMhNavigation)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.MaMhNavigation.MaMh)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.MaHkNavigation)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.MaHkNavigation.MaHk)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.DiemQt)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.DiemQt)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.DiemThi)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.DiemThi)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.DiemTb)
            </dt>
            <dd class="text-lg font-semibold text-blue-600">
                @Html.DisplayFor(model => model.DiemTb)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.XepLoai)
            </dt>
            <dd class="text-lg">
                <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full 
                    @(Model.XepLoai == "Giỏi" ? "bg-blue-100 text-blue-800" : 
                      Model.XepLoai == "Khá" ? "bg-green-100 text-green-800" : 
                      Model.XepLoai == "Trung bình" ? "bg-yellow-100 text-yellow-800" : 
                      "bg-red-100 text-red-800")">
                    @Html.DisplayFor(model => model.XepLoai)
                </span>
            </dd>
        </div>
    </dl>

    <div class="flex items-center space-x-4 pt-6 mt-6 border-t border-gray-200">
        <a asp-action="Edit" asp-route-id="@Model?.MaBd" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg">
            <i class="fa-solid fa-edit mr-2"></i>Chỉnh sửa
        </a>
        <a asp-action="Index" class="inline-flex items-center px-6 py-3 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">
            <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại danh sách
        </a>
    </div>
</div>
