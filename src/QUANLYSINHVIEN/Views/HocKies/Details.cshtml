@model QUANLYSINHVIEN.Models.HocKy

@{
    ViewData["Title"] = "Chi tiết Học kỳ";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Chi tiết Học kỳ</h1>
    <p class="text-gray-600 mt-2">Thông tin chi tiết về học kỳ</p>
</div>

<div class="bg-white rounded-lg shadow-md p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.MaHk)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.MaHk)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.TenHk)
            </dt>
            <dd class="text-lg font-semibold text-gray-900">
                @Html.DisplayFor(model => model.TenHk)
            </dd>
        </div>
        <div class="border-b border-gray-200 pb-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">
                @Html.DisplayNameFor(model => model.NamHoc)
            </dt>
            <dd class="text-lg text-gray-900">
                @Html.DisplayFor(model => model.NamHoc)
            </dd>
        </div>
    </dl>

    <div class="flex items-center space-x-4 pt-6 mt-6 border-t border-gray-200">
        <a asp-action="Edit" asp-route-id="@Model?.MaHk" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg">
            <i class="fa-solid fa-edit mr-2"></i>Chỉnh sửa
        </a>
        <a asp-action="Index" class="inline-flex items-center px-6 py-3 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">
            <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại danh sách
        </a>
    </div>
</div>
