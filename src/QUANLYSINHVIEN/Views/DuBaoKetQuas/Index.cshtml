@model IEnumerable<QUANLYSINHVIEN.Models.DuBaoKetQua>

@{
    ViewData["Title"] = "Dự báo Kết quả";
}

<div class="mb-6">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-3xl font-bold text-gray-900 flex items-center">
            <i class="fa-solid fa-brain text-purple-600 mr-3"></i>
            KẾT QUẢ DỰ BÁO TỪ AI
        </h1>
        <a asp-action="TaoDuBao" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors shadow-md hover:shadow-lg">
            <i class="fa-solid fa-plus mr-2"></i>Chạy Dự báo Mới
        </a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg flex items-center">
        <i class="fa-solid fa-circle-exclamation mr-2"></i>
        <span>@TempData["Error"]</span>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg flex items-center">
        <i class="fa-solid fa-circle-check mr-2"></i>
        <span>@TempData["Success"]</span>
    </div>
}

<div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gradient-to-r from-purple-600 to-purple-700">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Sinh Viên</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Ngày Dự Báo</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Dự báo Xếp loại</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Mô tả chi tiết từ AI</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm font-semibold text-purple-600">@Html.DisplayFor(modelItem => item.MaSvNavigation.HoTen)</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-500">@item.NgayDuBao?.ToString("dd/MM/yyyy HH:mm")</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (item.DuBaoXepLoai == "Giỏi")
                            {
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">Giỏi</span>
                            }
                            else if (item.DuBaoXepLoai == "Trung bình")
                            {
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Trung bình</span>
                            }
                            else
                            {
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Nguy cơ Yếu</span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-700">@item.MoTaPhanTich</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>