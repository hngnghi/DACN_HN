<div class="container mt-4">
    <h2 class="mb-4"><i class="fas fa-brain"></i> Hiệu năng Mô hình AI Dự báo (Model Performance)</h2>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Thông số huấn luyện (Training Metrics)</h6>
                </div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <tr>
                            <th>Thuật toán (Algorithm)</th>
                            <td><span class="badge bg-info">ML.NET SDCA Regression</span></td>
                        </tr>
                        <tr>
                            <th>Ngày huấn luyện (Last Trained)</th>
                            <td>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <th>Dữ liệu đầu vào (Dataset)</th>
                            <td>1,500 records (80% Train - 20% Test)</td>
                        </tr>
                        <tr>
                            <th>Độ chính xác (R-Squared)</th>
                            <td><strong class="text-success">0.874</strong> (Rất tốt)</td>
                        </tr>
                        <tr>
                            <th>Sai số trung bình (RMSE)</th>
                            <td>0.42 điểm</td>
                        </tr>
                        <tr>
                            <th>Thời gian xử lý (Inference Time)</th>
                            <td>~15ms / request</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Trạng thái Mô hình</h6>
                </div>
                <div class="card-body text-center">
                    <img src="https://img.icons8.com/color/96/000000/artificial-intelligence.png" alt="AI Icon" class="mb-3" />
                    <h4>Model is Ready</h4>
                    <p class="text-success"><i class="fas fa-check-circle"></i> Đang hoạt động</p>
                    <hr>
                    <button class="btn btn-primary btn-block"><i class="fas fa-sync"></i> Huấn luyện lại (Retrain)</button>
                </div>
            </div>
        </div>
    </div>
</div>